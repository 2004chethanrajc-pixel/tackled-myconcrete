{
  "expo": {
    "name": "My Concrete",
    "slug": "my-concrete",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",

    "icon": "./src/assets/icon.png",

    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.construction.management"
    },

    "android": {
      "package": "com.construction.management",
      "usesCleartextTraffic": true,
      "networkSecurityConfig": "./android/app/src/main/res/xml/network_security_config.xml",

      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },

      "notification": {
        "icon": "./src/assets/icon.png",
        "color": "#ffffff"
      },

      "permissions": [
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },

    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/logo.png"
    },

    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "expo-font",
      "expo-asset"
    ],

    "extra": {
      "apiHost": "apimc.tackled.co.in",
      "apiPort": "5001",
      "apiProtocol": "https",
      "eas": {
        "projectId": "885ab7c8-69de-4f9c-ba49-4b775f2d37f0"
      }
    },

    "owner": "chethanraj.c"
  }
}